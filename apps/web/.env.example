# ─────────────────────────────────────────────────────────────────
# Firebase Web SDK config — copy file to `.env.local` and fill in.
# Get these from: Firebase Console → Project Settings → Your apps →
# Web app config. NEXT_PUBLIC_ prefix is required for client-side use.
# ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional — set to "true" to use Firebase emulator suite during local dev.
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false

# ─────────────────────────────────────────────────────────────────
# Firebase Admin SDK (server-only) — required for /api/admin/* routes
# such as reset-password. Paste the full JSON of serviceAccount.json
# on ONE line (the route also accepts pretty-printed JSON).
# Locally you can leave this blank — the route falls back to reading
# serviceAccount.json at repo root (already gitignored).
# On Vercel: Settings → Environment Variables → add as a single-line
# Secret. Restart deployment after adding.
# ─────────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT=
