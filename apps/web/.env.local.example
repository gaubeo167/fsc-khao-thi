# Origin where the Fastify API is reachable.
NEXT_PUBLIC_API_ORIGIN=http://localhost:3001

# ─── AI · TEXT + VISION ────────────────────────────────────────────
# Cần ÍT NHẤT 1 trong 2 key dưới. Server tự chọn provider:
#   ANTHROPIC_API_KEY có → dùng Claude Haiku 4.5 (chất lượng cao, ~$0.001/lần).
#   Không có → fallback Gemini 2.5 Flash (MIỄN PHÍ 1500 request/ngày).

# Anthropic Claude — paid pay-as-you-go.
# Key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini — free tier 1500 req/ngày, 15 RPM.
# Key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── AI · SINH ẢNH (OpenAI DALL-E / gpt-image-1) ───────────────────
# Chỉ dùng cho /api/ai/generate-image. Tuỳ chọn — nếu không có thì
# nút "Sinh ảnh" trong dialog AI sẽ báo missing key.
# Key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
