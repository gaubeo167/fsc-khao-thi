rules_version = '2';

// FSC Exam Platform — Firestore security rules.
//
// Roles (stored in /users/{uid}.role): "superadmin" | "admin" | "teacher" | "student".
// Campus isolation (stored in /users/{uid}.campusId) enforced server-side here —
// the client-side checks in useUserScope are UX hints only; this is the real gate.
//
// Conventions:
//   • Every doc under /campuses/{cid}/... requires the caller's campusId to
//     match {cid} (superadmin bypasses).
//   • Personal kho (kho="personal", ownerId=caller) is always writable by owner.
//   • Campus kho (kho="campus") requires admin/superadmin OR teacher-with-permission
//     to create; pending → approved requires admin/superadmin (TBM duyệt flow).

service cloud.firestore {
  match /databases/{database}/documents {

    // ───── Helper functions ───────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function uid() {
      return request.auth.uid;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }
    function role() {
      return userDoc().role;
    }
    function callerCampusId() {
      return userDoc().campusId;
    }
    function isSuperadmin() {
      return isSignedIn() && role() == "superadmin";
    }
    // "admin" tier — anyone with full mutation rights inside their campus.
    // Matches the actual role names defined in auth-store: superadmin,
    // academic-director, campus-admin. (Old code used just "admin" — was
    // a bug that locked campus-admin out of /grades, /classes, /subjects
    // and other catalog writes.)
    function isAdmin() {
      return isSignedIn() && (
        role() == "superadmin" ||
        role() == "academic-director" ||
        role() == "campus-admin"
      );
    }
    function isTeacherOrAbove() {
      return isSignedIn() && (
        role() == "teacher" ||
        role() == "subject-lead" ||
        role() == "campus-admin" ||
        role() == "academic-director" ||
        role() == "superadmin"
      );
    }
    function inSameCampus(cid) {
      return isSuperadmin() || callerCampusId() == cid;
    }

    // ───── /users — profile + role + scope ────────────────────────────────
    // Read is intentionally PUBLIC because the login page maps a typed
    // username / mã HS to the underlying Firebase Auth email before
    // calling signInWithEmailAndPassword — and that lookup runs BEFORE
    // the user is signed in. Profile fields here don't include
    // passwords or secrets; emails / roles are already exposed via
    // enrollment lists. UI does per-campus filtering after read.
    //
    // Writes stay tightly gated.
    match /users/{userId} {
      allow read: if true;
      allow create: if isAdmin() && (
        isSuperadmin() ||
        request.resource.data.campusId == callerCampusId()
      );
      allow update: if isSignedIn() && (
        isSuperadmin() ||
        (isAdmin() && resource.data.campusId == callerCampusId()) ||
        (uid() == userId &&
          // Self can only change profile fields, not role/campus/permissions.
          request.resource.data.role == resource.data.role &&
          request.resource.data.campusId == resource.data.campusId)
      );
      allow delete: if isAdmin() && (
        isSuperadmin() || resource.data.campusId == callerCampusId()
      );
    }

    // ───── /campuses — superadmin-only writes ─────────────────────────────
    // Read is open to any signed-in user. Per-doc gating via dynamic
    // `inSameCampus()` made collection-level `onSnapshot` queries fail
    // (Firestore denies the entire query when the rule can't be
    // statically evaluated per-doc). Campus metadata (name, tier,
    // gradeIds) isn't sensitive — the heavy filtering happens in the
    // UI based on session.campusId.
    match /campuses/{campusId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperadmin();
    }

    // ───── /subjects, /grades, /classes — campus-scoped catalog ───────────
    // Catalog data is readable by any signed-in user. UI filters by
    // `subject.campusIds` to scope per-campus. Dynamic per-doc rules
    // break collection-level onSnapshot queries.
    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    match /grades/{gradeId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ───── /toc_nodes — table-of-contents per subject/grade ───────────────
    match /toc_nodes/{nodeId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isTeacherOrAbove();
    }

    // ───── /teaching_assignments — teacher↔class↔subject mapping ──────────
    match /teaching_assignments/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ───── /proctor_events — warnings + violations sent to students ───────
    // Proctor (teacher / admin) writes events; student acknowledges
    // them. Both sides need read access so the student's toast and
    // the proctor's queue stay in sync.
    match /proctor_events/{id} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrAbove();
      // Acknowledge = student updates their own row; teacher can edit/
      // delete anything they sent.
      allow update: if isSignedIn();
      allow delete: if isTeacherOrAbove();
    }

    // ───── /questions ─────────────────────────────────────────────────────
    // Read is open to any signed-in user. UI already filters by kho /
    // ownerId / campusId. (Dynamic per-doc rules broke list queries:
    // copying or creating a question made the whole onSnapshot fail and
    // wiped the local state — root cause of "tất cả câu hỏi đều biến
    // mất sau khi copy".)
    //
    // Writes stay strict.
    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrAbove() &&
        request.resource.data.ownerId == uid() &&
        (request.resource.data.kho == "personal" ||
          request.resource.data.status == "pending");
      allow update: if isSignedIn() && (
        (isAdmin() && inSameCampus(resource.data.campusId)) ||
        (resource.data.ownerId == uid() &&
          (resource.data.kho == "personal" || resource.data.status == "pending") &&
          request.resource.data.status == resource.data.status)
      );
      allow delete: if isSignedIn() && (
        (isAdmin() && inSameCampus(resource.data.campusId)) ||
        (resource.data.ownerId == uid() && resource.data.kho == "personal")
      );
    }

    // ───── /blueprints, /packages — same kho pattern as questions ─────────
    // Reads open to any signed-in user (UI filters); writes strict.
    match /blueprints/{id} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrAbove() &&
        request.resource.data.ownerId == uid();
      allow update, delete: if isSignedIn() && (
        isAdmin() || resource.data.ownerId == uid()
      );
    }
    match /packages/{id} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrAbove() &&
        request.resource.data.ownerId == uid();
      allow update, delete: if isSignedIn() && (
        isAdmin() || resource.data.ownerId == uid()
      );
    }

    // ───── /shifts — exam shifts (ca thi) ─────────────────────────────────
    // Anyone in the same campus can READ a shift. Per-student eligibility
    // (rooms[].studentIds) is checked in the UI on top of this gate — the
    // shift metadata is non-sensitive (name, time, status).
    // Reads open to any signed-in user — UI filters by campus / role.
    // Dynamic per-doc rules block collection-level onSnapshot which
    // wiped the local mirror to [] on every reload (root cause of
    // "mỗi lần đẩy code lại mất ca thi": writes that fell through to
    // the strict create rule silently failed → state empty on next
    // load).
    match /shifts/{shiftId} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrAbove() &&
        request.resource.data.ownerId == uid();
      allow update, delete: if isSignedIn() && (
        isAdmin() || resource.data.ownerId == uid()
      );
    }

    // ───── /attempts — student submissions ────────────────────────────────
    // Students read ONLY their own attempts (scoped query
    // where studentId == uid); teacher+ read all for grading / monitoring
    // / reports. Enforcing the scope here forces the client to query with
    // a filter, which is what keeps per-student login load bounded as the
    // attempts collection grows.
    match /attempts/{attemptId} {
      allow read: if isSignedIn() && (
        resource.data.studentId == uid() ||
        isTeacherOrAbove()
      );
      allow create: if isSignedIn() &&
        request.resource.data.studentId == uid();
      allow update: if isSignedIn() && (
        (resource.data.studentId == uid() &&
          resource.data.submittedAt == null) ||
        isTeacherOrAbove()
      );
      allow delete: if isAdmin();
    }

    // ───── /grades_essay — manual essay grading by teacher ────────────────
    match /grades_essay/{gradeId} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrAbove();
      allow update, delete: if isTeacherOrAbove();
    }

    // ───── /grading_assignments — who grades which shift's essays ─────────
    match /grading_assignments/{id} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ───── /exam_forms — frozen snapshots of exam content ─────────────────
    // These are the IMMUTABLE materialized versions of an exam,
    // attached to a shift. The runtime exam page reads them so any
    // mid-exam edit of /questions can't change what students see.
    //
    // Reads: any signed-in user (the variant a student receives is
    //   computed client-side; the doc itself is non-sensitive once
    //   the shift starts).
    // Writes: shift owner or campus admin. Lifecycle field can flip
    //   from "active" → "archived" but content fields must not be
    //   mutated post-write (enforced UI-side for now; Phase D adds
    //   field-level rule via request.resource.data.variants ==
    //   resource.data.variants).
    match /exam_forms/{formId} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrAbove() &&
        request.resource.data.materializedBy == uid();
      allow update: if isSignedIn() && (
        isAdmin() ||
        // Owner of the originating shift can republish (archive old +
        // create new) — but we still scope to teacher-or-above.
        isTeacherOrAbove()
      );
      // Hard delete is forbidden — soft-archive only. Lifecycle flips
      // to "archived" via update, never delete.
      allow delete: if false;
    }

    // ───── /learning_materials — uploaded videos / PDFs / docs ────────────
    // Mirrors /questions: read by signed-in (UI filters by kho/campus/
    // approval), strict writes.
    match /learning_materials/{id} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrAbove() &&
        request.resource.data.ownerId == uid() &&
        (request.resource.data.kho == "personal" ||
          request.resource.data.status == "pending");
      allow update: if isSignedIn() && (
        (isAdmin() && inSameCampus(resource.data.campusId)) ||
        (resource.data.ownerId == uid() &&
          (resource.data.kho == "personal" || resource.data.status == "pending"))
      );
      allow delete: if false; // soft-archive only
    }

    // ───── /homework — BTVN giáo viên giao ────────────────────────────────
    // Reads open to any signed-in user. Writes are scoped to the owner
    // (teacher) or campus admin in the UI; rules give teacher+ the
    // baseline. Status workflow + classIds filtering happens client-side.
    match /homework/{id} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrAbove() &&
        request.resource.data.ownerId == uid();
      allow update, delete: if isSignedIn() && (
        isAdmin() || resource.data.ownerId == uid()
      );
    }

    // ───── /homework_attempts — per-student attempts ──────────────────────
    // Students read ONLY their own attempt (scoped query
    // where studentId == uid); teachers + admins read all for the stats
    // page. The student-side scoping is critical for scale: an unfiltered
    // read would let one student's save fan out to every other student's
    // listener. Rules enforce the scope so the client query MUST filter.
    match /homework_attempts/{id} {
      allow read: if isSignedIn() && (
        resource.data.studentId == uid() ||
        isTeacherOrAbove()
      );
      allow create: if isSignedIn() &&
        request.resource.data.studentId == uid();
      allow update: if isSignedIn() && (
        (resource.data.studentId == uid() &&
          resource.data.submittedAt == null) ||
        isTeacherOrAbove()
      );
      // Hard delete forbidden once attempted — preserve report data.
      allow delete: if isAdmin();
    }

    // ───── /audit_events — append-only audit log ──────────────────────────
    // Every mutation of a production entity emits one of these. The
    // contract: create-only, never update or delete. Reads scoped to
    // admins (or self) for now; UI will filter further.
    //
    // Even superadmin cannot edit or delete an audit row — that's the
    // whole point. Production runbook: if a row is wrong, append a
    // CORRECTING event, don't tamper.
    match /audit_events/{eventId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() &&
        request.resource.data.actorUid == uid();
      allow update, delete: if false;
    }

    // ───── Default deny — anything not matched above is forbidden ─────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
